# ---------------------------------------------------------------------------
# WriteMyWrongs — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Public site URL (used for metadata, OG, auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# PostHog analytics (optional locally)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend transactional email (server-only)
RESEND_API_KEY=

# OpenRouter — optional AI writing feedback (server-only)
OPENROUTER_API_KEY=
